# Ev's Dance — Backend environment
# Copy to .env and fill in values.

# Anthropic API key (required for Claude)
EVS_ANTHROPIC_API_KEY=sk-ant-...

# Postgres
EVS_POSTGRES_HOST=localhost
EVS_POSTGRES_PORT=5432
EVS_POSTGRES_USER=evsdance
EVS_POSTGRES_PASSWORD=
EVS_POSTGRES_DB=evsdance

# Redis
EVS_REDIS_HOST=localhost
EVS_REDIS_PORT=6379
EVS_REDIS_DB=0
# EVS_REDIS_PASSWORD=

# Optional
# EVS_DEBUG=false
